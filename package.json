{
  "name": "pitchos-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:client": "bun run --filter client dev",
    "dev:next-app": "bun run --filter next-app dev",
    "dev:relay": "bun run --filter relay-service dev",
    "dev": "bun run dev:client & bun run dev:relay & bun run dev:next-app",
    "build": "bun run --filter '*' build",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "depcruise": "depcruise --config .dependency-cruiser.js apps/client/src",
    "postinstall": "powershell -Command \"Get-ChildItem -Path node_modules -Filter '*.node' -Recurse -ErrorAction SilentlyContinue | Remove-Item -Force -ErrorAction SilentlyContinue\""
  },
  "devDependencies": {
    "dependency-cruiser": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "bare-runtime-linux-x64": "^1.30.3",
    "pear-electron": "^1.7.28"
  },
  "license": "Apache-2.0"
}
